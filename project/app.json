{
  "expo": {
    "name": "Wink!",
    "slug": "pokedate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/appicon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a1a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pokedate.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "PokeDate needs your location to show you on the map and find nearby matches.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "PokeDate uses your location in the background to keep your position updated.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/appicon.png",
        "backgroundColor": "#0a0a1a"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.pokedate.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "FOREGROUND_SERVICE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@maplibre/maplibre-react-native",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "PokeDate needs your location to show you on the map and find nearby matches."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "d16bd265-0708-4762-9448-221ccb6b5bb8"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d16bd265-0708-4762-9448-221ccb6b5bb8"
    },
    "owner": "ipanda2468"
  }
}
